{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "moduleResolution": "node16",
    "types": ["node"],
    "declaration": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "incremental": true,
    "composite": true,
    "skipLibCheck": true
  },
  "include": ["lib", "rolldown.config.ts"],
  "exclude": ["node_modules", "dist"]
}
