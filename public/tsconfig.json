{
  "compilerOptions": {
    "target": "ES2020",
    "module": "umd",
    "moduleResolution": "node10",
    "types": ["jquery"],
    "declaration": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "incremental": true,
    "composite": true,
    "skipLibCheck": true
  },
  "include": ["lib"]
}
